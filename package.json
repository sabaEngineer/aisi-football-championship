{
  "name": "aisi-football-championship",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed-add-players": "npx tsx prisma/seed-add-players.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "db:studio": "prisma studio",
    "db:migrate-payment-modal": "prisma db execute --file prisma/add-payment-modal-column.sql --schema prisma/schema.prisma",
    "db:migrate-app-setting": "prisma db execute --file prisma/add-app-setting.sql --schema prisma/schema.prisma",
    "db:migrate-saves": "prisma db execute --file prisma/add-saves-column.sql --schema prisma/schema.prisma",
    "db:migrate-match-group": "prisma db execute --file prisma/add-match-group-number.sql --schema prisma/schema.prisma"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}

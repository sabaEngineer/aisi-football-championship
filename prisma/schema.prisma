generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  PLAYER
  STAFF
}



enum ChampionshipStatus {
  DRAFT
  REGISTRATION
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TeamMemberStatus {
  ACTIVE
  RESERVE
  LEFT
}

enum TeamMemberRole {
  CAPTAIN
  PLAYER
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id              Int      @id @default(autoincrement())
  fullName        String
  email           String   @unique
  phone           String
  password        String
  role            UserRole @default(PLAYER)
  position        String?
  socialMediaLink String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teamMemberships   TeamMember[]
  matchStaff        MatchStaff[]
  matchStats        MatchPlayerStat[]
  supportMessages  SupportMessage[]
  supportReplies   SupportMessage[] @relation("AdminReplies")
  nominationWins   NominationWinner[]
}

// ─── SupportMessage (user to admin chat) ──────────────────────────────────────

model SupportMessage {
  id         Int       @id @default(autoincrement())
  userId     Int
  message    String
  adminReply String?
  repliedAt  DateTime?
  repliedBy  Int?

  createdAt DateTime @default(now())

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin  User? @relation("AdminReplies", fields: [repliedBy], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ─── Championship ────────────────────────────────────────────────────────────

model Championship {
  id                 Int                @id @default(autoincrement())
  name               String
  description        String?
  maxTeams           Int
  maxPlayersPerTeam  Int
  maxReservesPerTeam Int                @default(5)
  status             ChampionshipStatus @default(DRAFT)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  teams       Team[]
  matches     Match[]
  sponsors    ChampionshipSponsor[]
  nominations Nomination[]
}

// ─── Team ────────────────────────────────────────────────────────────────────

model Team {
  id             Int      @id @default(autoincrement())
  name           String
  championshipId Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  championship  Championship     @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  members       TeamMember[]
  homeMatches   Match[]          @relation("HomeTeam")
  awayMatches   Match[]          @relation("AwayTeam")
  winnerMatches Match[]          @relation("MatchWinner")
  matchStats    MatchPlayerStat[]
  nominationWins NominationWinner[]

  @@unique([championshipId, name])
}

// ─── TeamMember (connects User to Team) ──────────────────────────────────────

model TeamMember {
  id                   Int              @id @default(autoincrement())
  userId               Int
  teamId               Int
  role                 TeamMemberRole   @default(PLAYER)
  position             String?
  positionX            Float?
  positionY            Float?
  status               TeamMemberStatus @default(ACTIVE)
  joinedAt             DateTime         @default(now())
  leftAt               DateTime?
  paymentModalShownAt  DateTime?        // when we showed the payment info modal (null = not shown yet)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

// ─── Match ───────────────────────────────────────────────────────────────────

model Match {
  id              Int         @id @default(autoincrement())
  championshipId  Int
  homeTeamId      Int?
  awayTeamId      Int?
  homeScore       Int         @default(0)
  awayScore       Int         @default(0)
  round           Int?
  bracketPosition Int?
  winnerId        Int?
  date            DateTime?
  time            String?
  location        String?
  locationUrl     String?
  description     String?
  status          MatchStatus @default(SCHEDULED)
  groupNumber     Int?        // null = knockout; 1..N = group stage round-robin
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  homeTeam     Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  winner       Team?        @relation("MatchWinner", fields: [winnerId], references: [id])
  staff        MatchStaff[]
  playerStats  MatchPlayerStat[]
}

// ─── MatchPlayerStat (goals, assists per player per match) ────────────────────

model MatchPlayerStat {
  id      Int @id @default(autoincrement())
  matchId Int
  userId  Int
  teamId  Int
  goals   Int @default(0)
  assists Int @default(0)
  saves   Int @default(0) // goalkeeper saves (ბურთის მოგერიება)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

// ─── MatchStaff ──────────────────────────────────────────────────────────────

model MatchStaff {
  id      Int    @id @default(autoincrement())
  matchId Int
  userId  Int
  role    String

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
}

// ─── Sponsor ─────────────────────────────────────────────────────────────────

model Sponsor {
  id        Int      @id @default(autoincrement())
  name      String
  logo      String?
  website   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  championships ChampionshipSponsor[]
  nominations   Nomination[]
}

// ─── Nomination (awards/prizes per championship) ───────────────────────────────

model Nomination {
  id             Int      @id @default(autoincrement())
  championshipId Int
  name           String
  prize          String?
  sponsorId      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  championship Championship      @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  sponsor      Sponsor?          @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  winner       NominationWinner?
}

model NominationWinner {
  id           Int      @id @default(autoincrement())
  nominationId Int      @unique
  userId       Int?     // player or staff member
  teamId       Int?     // whole team
  awardedAt   DateTime @default(now())

  nomination Nomination @relation(fields: [nominationId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team       Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

// ─── AppSetting (key-value for global app config) ──────────────────────────────

model AppSetting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String // stored as string; parse as number for charity_collected_amount
}

// ─── ChampionshipSponsor (many-to-many) ──────────────────────────────────────

model ChampionshipSponsor {
  id             Int      @id @default(autoincrement())
  championshipId Int
  sponsorId      Int
  createdAt      DateTime @default(now())

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  sponsor      Sponsor      @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@unique([championshipId, sponsorId])
}
